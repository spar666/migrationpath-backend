# Application Configuration
NODE_ENV=development
PORT=3000

# Authentication (Local JWT)
# Generate a strong secret for production
JWT_SECRET=super-secret-key-change-me-in-production
JWT_EXPIRES_IN=7d

# Database Configuration (PostgreSQL/TypeORM)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=postgres

# External Services
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your-strapi-api-token

# Reverse proxy / load balancer trust. Leave as false for local dev or any
# deployment with no proxy in front. If you're behind one reverse proxy
# (e.g. a single Nginx, Vercel, Render, Heroku router), set to "true".
# If you're behind more than one hop, set to the hop count (e.g. "2").
# This affects how POST /leads' rate limit identifies "one visitor" — get
# it wrong and either everyone shares one IP bucket, or IPs become spoofable.
TRUST_PROXY=false

# Lead Notifications (all optional — leads are still captured and visible
# via GET /leads / the admin panel if none of this is set; you'll just miss
# real-time alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=leads@migrationpath.example
SLACK_LEADS_WEBHOOK_URL=
LEAD_NOTIFICATION_EMAIL=
# Used to build a direct "view in admin" link in lead notifications.
# e.g. https://app.migrationpath.example
ADMIN_BASE_URL=
